PORT=5000
FRONTEND_URL=http://localhost:5173

# PostgreSQL database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twinn_db
DB_USER=postgres
DB_PASSWORD=

# Railway PostgreSQL (auto-filled on Railway)
DATABASE_URL=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Instagram OAuth
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_ACCESS_TOKEN=

# YouTube OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# App login via Google (YouTube login = Google login).
# Reuses YOUTUBE_CLIENT_ID/SECRET above if these are left blank.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Secret used to sign login session tokens (JWT). REQUIRED in production.
JWT_SECRET=
# Public URL of THIS backend, e.g. https://your-app.onrender.com
# (used to build the OAuth redirect URI). Falls back to RAILWAY_URL/localhost.
PUBLIC_URL=

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Optional shared secret for the relay status heartbeat.
# If set, the local relay must send the same value as the x-relay-token header
# (RELAY_STATUS_TOKEN in the relay's environment) or its status push is rejected.
RELAY_STATUS_TOKEN=